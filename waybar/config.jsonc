      "class<zathura>": "’ćü",
      "class<org.pwmt.zathura>": "’ćü",

      "class<[Ss]team>": "’åČ",
      "class<neovide>": "Ņ¤ģ",
      "class<[Cc]ursor>": "Ņ£ī",

      "class<libreoffice-writer>": "¾░łÖ",
      "class<libreoffice-calc>": "¾░ē¦",
      "class<libreoffice-impress>": "¾░Éæ",
      "class<libreoffice-draw>": "’ćģ",
      "class<soffice>": "’ćé",

      "class<[Pp]ostman>": "’æü",
      "class<dbeaver>": "’ćĆ",
      "class<[Ff]ile[Zz]illa>": "¾░ü»",
      "class<org.remmina.Remmina>": "’äē",
      "class<virt-manager>": "’äē",
      "class<calibre>": "’ĆŁ",
      "class<org.gnome.FileRoller>": "’ćå",
      "class<file-roller>": "’ćå",
