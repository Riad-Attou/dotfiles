# Tokyo Night theme
set default-bg                  "#1a1b26"
set default-fg                  "#c0caf5"
set statusbar-bg                "#16161e"
set statusbar-fg                "#c0caf5"
set inputbar-bg                 "#1a1b26"
set inputbar-fg                 "#c0caf5"
set notification-bg             "#1a1b26"
set notification-fg             "#c0caf5"
set notification-error-bg       "#1a1b26"
set notification-error-fg       "#f7768e"
set notification-warning-bg     "#1a1b26"
set notification-warning-fg     "#e0af68"
set highlight-color             rgba(122,162,247,0.4)
set highlight-active-color      rgba(187,154,247,0.6)
set completion-bg               "#16161e"
set completion-fg               "#c0caf5"
set completion-highlight-bg     "#283457"
set completion-highlight-fg     "#7aa2f7"
set recolor-lightcolor          "#1a1b26"
set recolor-darkcolor           "#c0caf5"

# Behaviour
set recolor                     true
set recolor-keephue             true
set scroll-page-aware           true
set scroll-full-overlap         0.1
set zoom-min                    10
set guioptions                  s
set font                        "JetBrainsMono Nerd Font 10"

# Keybindings (vim-style already default, these are extras)
map r reload
map R rotate
map i recolor
map p print
map <F1>    exec "kitty --title Cheatsheet -e sh -c 'cat ~/.config/zathura/cheatsheet.txt; read -rsn1'"
map <Right> navigate next
map <Left>  navigate previous
