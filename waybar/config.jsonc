      "class<jetbrains-idea>": "Ņ£ī",
      "class<jetbrains-pycharm.*>": "Ņ£ī",
      "class<jetbrains-webstorm>": "Ņ£ī",
      "class<jetbrains-goland>": "Ņ£ī",
      "class<jetbrains-clion>": "Ņ£ī",
      "class<jetbrains-rider>": "Ņ£ī",
      "class<jetbrains-datagrip>": "Ņ£ī",
      "class<jetbrains-phpstorm>": "Ņ£ī",
      "class<jetbrains-rustrover>": "Ņ£ī",
