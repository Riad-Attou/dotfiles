    "persistent-workspaces": { "*": 5 },
    "on-click": "activate",
    "sort-by-number": true,
    "on-scroll-up": "hyprctl dispatch workspace e+1",
    "on-scroll-down": "hyprctl dispatch workspace e-1"
  },

  "hyprland/window": {
    "format": "{}",
    "max-length": 50,
    "separate-outputs": true
  },

  "clock": {
    "format": "  {:%H:%M}",
    "on-click": "python3 ~/.config/waybar/scripts/calendar-popup.py",
    "tooltip": false
  },

  "battery": {
    "states": {
      "warning": 30,
      "critical": 15
    },
    "format": "{icon} {capacity}%",
    "format-charging": "¾░éä {capacity}%",
    "format-plugged": "¾░Üź {capacity}%",
    "format-icons": ["¾░éÄ", "¾░ü║", "¾░ü╗", "¾░ü╝", "¾░üĮ", "¾░üŠ", "¾░ü┐", "¾░éĆ", "¾░éü", "¾░éé", "¾░ü╣"],
    "on-click": "~/.config/waybar/scripts/battery-popup.py"
  },

  "network": {
    "format-wifi": "¾░ż© {signalStrength}%",
    "format-ethernet": "¾░łĆ {ipaddr}",
    "format-disconnected": "¾░żŁ Disconnected",
    "tooltip-format": "{essid} ({signalStrength}%) ŌĆö {ipaddr}",
    "on-click": "python3 ~/.config/waybar/scripts/wifi-popup.py"
  },

  "pulseaudio": {
    "format": "{icon} {volume}%",
    "format-muted": "¾░Ø¤ Muted",
    "format-icons": {
      "default": ["¾░Ģ┐", "¾░¢Ć", "¾░ĢŠ"]
    },
    "signal": 1,
    "on-click": "~/.config/waybar/scripts/volume-popup.py",
    "on-scroll-up": "wpctl set-volume @DEFAULT_AUDIO_SINK@ 5%+",
    "on-scroll-down": "wpctl set-volume @DEFAULT_AUDIO_SINK@ 5%-"
  },

  "backlight": {
    "format": "{icon} {percent}%",
    "format-icons": ["¾░ā×", "¾░ā¤", "¾░āĀ"],
    "on-click": "python3 ~/.config/waybar/scripts/brightness-popup.py",
    "on-scroll-up": "brightnessctl set 5%+",
    "on-scroll-down": "brightnessctl set 5%-"
  },

  "tray": {
    "spacing": 8
  },

  "bluetooth": {
    "format": "¾░é»",
    "format-disabled": "¾░é▓",
    "format-connected": "¾░é▒ {device_alias}",
    "format-connected-battery": "¾░é▒ {device_alias} {device_battery_percentage}%",
    "tooltip-format": "{controller_alias} ({controller_address})",
    "tooltip-format-connected": "{controller_alias}\n{device_enumerate}",
    "tooltip-format-enumerate-connected": "  {device_alias}",
    "on-click": "python3 ~/.config/waybar/scripts/bluetooth-popup.py"
  },

  "custom/weather": {
    "exec": "~/.config/waybar/scripts/weather.sh",
    "return-type": "json",
    "interval": 1800,
    "signal": 8,
    "on-click": "~/.config/waybar/scripts/weather-config.sh",
    "format": "{}",
    "tooltip": true
  },

  "custom/media": {
    "exec": "~/.config/waybar/scripts/media.sh",
    "return-type": "json",
    "interval": 5,
    "on-click": "python3 ~/.config/waybar/scripts/media-popup.py",
    "on-scroll-up": "playerctl next",
    "on-scroll-down": "playerctl previous",
    "format": "{}",
    "escape": true
  },

  "custom/profile-dot": {
    "exec": "~/.config/waybar/scripts/profile-dot.sh",
    "return-type": "json",
    "interval": 60,
    "signal": 2,
    "format": "{}",
    "tooltip": true
  },

  "custom/power": {
    "format": "ŌÅ╗",
    "on-click": "~/.config/waybar/scripts/power-menu.sh",
    "tooltip": false
  },

  "custom/updates": {
    "exec": "~/.config/waybar/scripts/updates.sh",
    "return-type": "json",
    "interval": 1800,
    "signal": 7,
    "tooltip": true,
    "on-click": "hyprctl dispatch focusworkspaceoncurrentmonitor 1 && kitty --title UpdateTerminal -e bash -c 'yay -Syu; echo; echo Done ŌĆö press any key to close; read -rsn1'"
  },

  "custom/mullvad": {
    "exec": "~/.config/waybar/scripts/mullvad.sh",
    "return-type": "json",
    "interval": 10,
    "tooltip": true,
    "on-click": "python3 ~/.config/waybar/scripts/mullvad-popup.py"
  }
}
