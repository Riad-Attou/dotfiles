{
  "layer": "top",
  "position": "top",
  "height": 30,
  "spacing": 4,
  "margin-top": 5,
  "margin-left": 10,
  "margin-right": 10,

  "modules-left": ["hyprland/workspaces", "hyprland/window"],
  "modules-center": ["clock"],
  "modules-right": ["tray", "custom/updates", "custom/media", "custom/weather", "bluetooth", "pulseaudio", "backlight", "battery", "custom/profile-dot", "custom/mullvad", "network", "custom/power"],

  "hyprland/workspaces": {
    "format": "{name} {windows}",
    "format-window-separator": " ",
    "window-rewrite-default": "’Ŗ£",
