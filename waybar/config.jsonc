      "class<org.qbittorrent.qBittorrent>": "’ĆÖ",
      "class<qbittorrent>": "’ĆÖ",
      "class<com.transmissionbt.Transmission>": "’ĆÖ",
      "class<transmission-gtk>": "’ĆÖ",
      "class<deluge>": "’ĆÖ",

      "class<flameshot>": "’Ć░",
      "class<org.gnome.Screenshot>": "’Ć░",

      "class<org.keepassxc.KeePassXC>": "’éä",
      "class<keepassxc>": "’éä",
      "class<[Bb]itwarden>": "’éä",

      "class<org.gnome.SystemMonitor>": "’łĆ",
      "class<io.missioncenter.MissionCenter>": "’łĆ",
      "class<org.gnome.DiskUtility>": "¾░ŗŖ",
      "class<gparted>": "¾░ŗŖ",

      "class<io.github.celluloid_player.Celluloid>": "’ĆĮ",
      "class<org.gnome.Totem>": "’ĆĮ",

      "class<org.gnome.Rhythmbox3>": "’Ćü",
      "class<net.strawberrymusicplayer.strawberry>": "’Ćü",
