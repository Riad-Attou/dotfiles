      "class<thunderbird>": "¾░ć░",
      "class<org.mozilla.Thunderbird>": "¾░ć░",

      "class<vlc>": "¾░Ģ╝",
      "class<mpv>": "’üŗ",

      "class<gimp.*>": "’ć╝",
      "class<org.gimp.Gimp>": "’ć╝",
      "class<inkscape>": "’ć╝",
      "class<org.inkscape.Inkscape>": "’ć╝",
